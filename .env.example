# ── SSH connection ─────────────────────────────────────
SSH_HOST=your-server-hostname
SSH_PORT=22
SSH_USER=your-username
SSH_KEY_PATH=~/.ssh/id_rsa
# SSH_PASSWORD=          # only if key is encrypted or no key auth

# ── Remote Ollama server ──────────────────────────────
# Per server standalone: 127.0.0.1
# Per cluster SLURM: hostname del nodo GPU (es. gnode10)
#   → lo trovi in ~/ollama-server/node_info.txt dopo sbatch
REMOTE_HOST=127.0.0.1
REMOTE_PORT=11434

# ── Local proxy ───────────────────────────────────────
LOCAL_HOST=127.0.0.1
LOCAL_PORT=11434
TUNNEL_PORT=11435

# ── Model ─────────────────────────────────────────────
MODEL_NAME=qwen2.5:14b
