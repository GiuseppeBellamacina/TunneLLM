# ── SSH connection ─────────────────────────────────────
SSH_HOST=your-server-hostname
SSH_PORT=22
SSH_USER=your-username
SSH_KEY_PATH=~/.ssh/id_rsa
# SSH_PASSWORD=          # only if key is encrypted or no key auth

# ── Remote vLLM server ────────────────────────────────
REMOTE_HOST=127.0.0.1
REMOTE_PORT=8000
# VLLM_API_KEY=          # only if vLLM was started with --api-key

# ── Local proxy ───────────────────────────────────────
LOCAL_HOST=127.0.0.1
LOCAL_PORT=11434
TUNNEL_PORT=11435

# ── Model ─────────────────────────────────────────────
MODEL_NAME=Qwen/Qwen2.5-14B-Instruct-AWQ
